rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Visit photos: visits/{visitId}/photos/{filename}
    match /visits/{visitId}/photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024 // max 10MB
        && request.resource.contentType.matches('image/.*');
    }

    // Checkin/checkout facade photos: visits/{visitId}/facade/{filename}
    match /visits/{visitId}/facade/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
