# Server
NODE_ENV=development
PORT=3000

# Database
# Supabase: use Shared Pooler (IPv4) for the running app — port 6543, user postgres.<project-ref>
# Example: postgresql://postgres.xxxxx:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database?schema=public
# Supabase: direct connection for prisma migrate / db pull — host db.<project-ref>.supabase.co, port 5432, user postgres
# Required because prisma/schema.prisma sets directUrl = env("DIRECT_URL")
DIRECT_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
# Optional: force runtime pgBouncer-safe params in Prisma client
PRISMA_USE_PGBOUNCER=false

# JWT (use strong random values in production; prefer Secret Manager on GCP)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins; include Firebase Hosting URLs in production)
# Example: https://mustafabucket.web.app,https://mustafabucket.firebaseapp.com
CORS_ORIGIN=http://localhost:5173

# Firebase Storage (do NOT commit .firebase-env.txt; use env vars or Secret Manager)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Optional
GEMINI_API_KEY=
SEED_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
